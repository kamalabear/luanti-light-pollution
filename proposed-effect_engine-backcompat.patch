-            sky_saved         = deep_copy(player:get_sky()) or {type = "regular"},
+            sky_saved         = capture_sky_state(player),
             last_pos          = nil,
             sky_applied       = false,
         }
@@ -91,11 +142,11 @@ function effect_engine.update(player)
     -- Apply or restore sky when the intensity changes meaningfully.
     if state.current_intensity < 0.001 then
         if state.sky_applied then
-            player:set_sky(deep_copy(state.sky_saved))
+            restore_sky(player, state.sky_saved)
             state.sky_applied = false
         end
     elseif math.abs(state.current_intensity - prev) > 0.001 or not state.sky_applied then
-        apply_tint(player, state.sky_saved, state.current_intensity)
+        apply_tint(player, state.sky_saved and state.sky_saved.value, state.current_intensity)
         state.sky_applied = true
     end
 end
@@ -103,7 +154,7 @@ minetest.register_on_leaveplayer(function(player)
     local name  = player:get_player_name()
